---
import { Icon } from 'astro-icon/components';
import type { Social } from '../lib/types';

export type Props = Social;

const { title, link, iconName } = Astro.props;
---

<a
  class="mr-4 mb-4 inline-flex flex-initial transform items-center rounded-full border-1 border-gray-300 px-4 py-1 font-mono text-xs text-gray-700 transition-colors transition-transform hover:scale-105 motion-reduce:transition-none motion-reduce:hover:transform-none dark:border-gray-700 dark:text-gray-300"
  href={link}
  target="_blank"
  rel="noreferrer noopener"
  aria-label={`${title} (opens in new tab)`}
>
  <Icon name={iconName} class="w-4" aria-hidden="true" />
  <span class="pl-2">{title}</span>
</a>
