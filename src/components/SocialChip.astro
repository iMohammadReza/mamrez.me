---
import { Icon } from 'astro-icon/components';
import type { Social } from '../lib/types';

export type Props = Social;

const { title, link, iconName } = Astro.props;
---

<a
  class="reduce-motion mr-4 mb-4 inline-flex flex-initial transform items-center rounded-full bg-gray-900 px-4 py-1 font-mono text-sm text-white transition-colors transition-transform hover:scale-105 hover:bg-gray-700 dark:bg-gray-200 dark:text-gray-900 dark:hover:bg-gray-400"
  href={link}
  target="_blank"
  rel="noreferrer noopener"
  aria-label={`${title} (opens in new tab)`}
>
  <Icon name={iconName} class="w-4" aria-hidden="true" />
  <span class="pl-2">{title}</span>
</a>
