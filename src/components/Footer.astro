---
import { header } from '../lib/config';

const currentYear = new Date().getFullYear();
---

<footer class="bg-white px-8 py-12 dark:bg-black">
  <p class="text-center font-mono text-sm font-light dark:text-gray-100">
    {`© ${currentYear} `}
    <a class="transition-colors hover:text-red-500" href="/">
      {`${header.firstName} ${header.lastName}. `}
    </a>
    All Rights Reserved.
  </p>
</footer>
