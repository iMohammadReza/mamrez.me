---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  link: string;
  date: string;
  summary: string;
}

const { title, link, summary, date: rawDate } = Astro.props;
const date = new Date(rawDate);
---

<article dir="auto" title={title} class="group mb-12 text-gray-700 dark:text-gray-300">
  <a href={link} aria-label={title} target="_blank" rel="noreferrer">
    <h3
      class="text-xl font-extrabold text-black transition-colors group-hover:text-red-500 group-hover:underline dark:text-white"
    >
      {title}
    </h3>
    <div class="text-md my-4 font-mono font-light" set:html={summary} />
    <div dir="ltr" class="flex text-sm">
      <span class="inline-flex items-center font-mono font-light">
        <Icon name="pixelarticons:clock" class="w-5" />
        <span class="pl-1">{date.toDateString()}</span>
      </span>
      <span class="px-3">|</span>
      <span
        class="inline-flex items-center font-mono font-light transition-colors group-hover:text-red-500 group-hover:underline"
      >
        <span class="pr-1">Read more</span>
        <Icon name="pixelarticons:open" class="w-5" />
      </span>
    </div>
  </a>
</article>
