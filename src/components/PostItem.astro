---
import { Icon } from 'astro-icon/components';
import type { Post } from '../lib/types';

export type Props = Post;

const { title, link, summary, date: rawDate } = Astro.props;
const date = new Date(rawDate);
---

<article dir="auto" title={title} class="group mt-12 dark:text-gray-200">
  <a href={link} aria-label={title} target="_blank" rel="noreferrer">
    <h3
      class="text-2xl font-extrabold transition-colors group-hover:text-red-500 group-hover:underline"
    >
      {title}
    </h3>
    <div class="my-4 font-sans text-xl font-light" set:html={summary} />
    <div dir="ltr" class="flex">
      <span class="inline-flex items-center font-mono font-bold">
        <Icon name="pixelarticons:clock" class="w-5" />
        <span class="pl-1">{date.toDateString()}</span>
      </span>
      <span class="px-3">|</span>
      <span
        class="inline-flex items-center font-mono font-bold transition-colors group-hover:text-red-500 group-hover:underline"
      >
        <span class="pr-1">Read more</span>
        <Icon name="pixelarticons:open" class="w-5" />
      </span>
    </div>
  </a>
</article>
