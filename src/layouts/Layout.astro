---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { DarkMode } from 'accessible-astro-components';
import SiteMeta from '../components/SiteMeta.astro';
import Footer from '../components/Footer.astro';
import DotBackground from '../components/DotBackground.astro';

interface Props {
  title?: string;
  footerLess?: boolean;
}

const { title, footerLess = false } = Astro.props;
---

<html lang="en" dir="ltr">
  <head>
    <ClientRouter />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <meta name="robots" content="index, follow" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,700;0,800;1,400&family=JetBrains+Mono:wght@300;400;700&display=swap"
      as="style"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,700;0,800;1,400&family=JetBrains+Mono:wght@300;400;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,700;0,800;1,400&family=JetBrains+Mono:wght@300;400;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <meta name="theme-color" content="#000000" />
    <meta name="msapplication-TileColor" content="#da532c" />
    <link rel="icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="mask-icon" href="/favicon/safari-pinned-tab.svg" color="#5bbad5" />
    <SiteMeta pageTitle={title} />
  </head>
  <body class="flex h-screen flex-col">
    <DotBackground />
    <main id="main-content" class="flex-1">
      <span class="theme-toggle-wrapper">
        <DarkMode />
      </span>
      <slot />
    </main>
    {!footerLess && <Footer />}
    <script async src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
  </body>
</html>
<style is:global>
  @reference "../styles/global.css";

  .reduce-motion {
    @apply motion-reduce:transition-none motion-reduce:hover:transform-none;
  }

  .section-title {
    @apply font-sans text-xl font-bold text-red-500 sm:text-2xl;
  }

  ::selection {
    @apply bg-red-500 text-gray-100;
  }

  ::-webkit-scrollbar {
    @apply h-2 w-2;
  }

  ::-webkit-scrollbar-thumb {
    @apply rounded-full bg-red-500;
  }

  ::-webkit-scrollbar-track {
    @apply bg-black;
  }

  :focus-visible {
    @apply outline-2 outline-offset-2 outline-red-500;
  }

  .theme-toggle-wrapper {
    @apply fixed top-4 right-4 z-50;
  }

  .theme-toggle-wrapper .darkmode-toggle {
    @apply flex h-10 w-10 cursor-pointer items-center justify-center rounded-full border border-gray-200/60 bg-white/80 text-gray-700 shadow-[0_2px_10px_rgba(0,0,0,0.08)] backdrop-blur-md transition-all duration-300 ease-out hover:scale-110 hover:shadow-[0_4px_16px_rgba(0,0,0,0.12)] active:scale-95 dark:border-gray-700/60 dark:bg-gray-800/80 dark:text-gray-200 dark:shadow-[0_2px_10px_rgba(0,0,0,0.3)] dark:hover:shadow-[0_4px_16px_rgba(0,0,0,0.4)];
  }

  .theme-toggle-wrapper .darkmode-toggle svg {
    @apply h-[18px] w-[18px] transition-transform duration-300 ease-out;
  }

  .theme-toggle-wrapper .darkmode-toggle:hover svg {
    @apply rotate-12;
  }
</style>
