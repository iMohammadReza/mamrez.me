---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import WaveDivider from '../components/WaveDivider.astro';
import Creations from '../components/Creations.astro';
import Playlists from '../components/Playlists.astro';
import Contact from '../components/Contact.astro';
import Posts from '../components/Posts.astro';
---

<Layout>
  <div>
    <Hero />
    <WaveDivider />
    <div class="bg-white dark:bg-black">
      <div class="px-8 py-16 lg:mx-auto lg:flex lg:max-w-6xl lg:flex-row-reverse">
        <aside class="lg:max-w-xs" aria-label="Creations, playlists and contact">
          <Creations />
          <Playlists />
          <Contact />
        </aside>
        <div class="flex-1 lg:mr-24">
          <h2 class="section-title">Recently Published</h2>
          <Posts />
        </div>
      </div>
    </div>
  </div>
</Layout>
